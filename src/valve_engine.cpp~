#include "valve_engine.h"
#include "../config/channel_config.h"

void valve_engine_init() {
    channel_config_init();
}

void valve_set(uint8_t channel_id, bool state) {
    Channel* ch = get_channel(channel_id);
    if (!ch) return;

    ch->state = state;
    ch->duration = 0;

    digitalWrite(ch->pin, state ? HIGH : LOW);
}

void valve_set_timed(uint8_t channel_id, unsigned long duration_ms) {
    Channel* ch = get_channel(channel_id);
    if (!ch) return;

    ch->state = true;
    ch->duration = duration_ms;
    ch->startTime = millis();

    digitalWrite(ch->pin, HIGH);
}

void valve_engine_task() {

    for (int i = 0; i < MAX_CHANNELS; i++) {

        Channel* ch = &channels[i];

        if (ch->state && ch->duration > 0) {
            if (millis() - ch->startTime >= ch->duration) {
                ch->state = false;
                ch->duration = 0;
                digitalWrite(ch->pin, LOW);
            }
        }
    }
}
